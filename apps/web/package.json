{
  "name": "@ar-replanteo/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:deps && tsc -p tsconfig.json && vite build",
    "test": "vitest run",
